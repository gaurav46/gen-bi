# Anthropic API key — used for SQL generation (Claude) and column description suggestions
ANTHROPIC_API_KEY=

# OpenAI API key — used for generating schema embeddings
OPENAI_API_KEY=

# Encryption key — used to encrypt stored database passwords (any random 32-char string)
ENCRYPTION_KEY=

# App database engine — "duckdb" (default, zero-config) or "postgresql"
DATABASE_ENGINE=duckdb

# DuckDB: path to the embedded database file (only used when DATABASE_ENGINE=duckdb)
DUCKDB_PATH=./data/genbi.db

# PostgreSQL: connection string (only used when DATABASE_ENGINE=postgresql)
# DATABASE_URL=postgresql://user:password@localhost:5432/genbi

# HTTP port (default: 3000)
# PORT=3000
